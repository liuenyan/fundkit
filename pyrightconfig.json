{
  "venvPath": ".",
  "venv": ".venv",
  "typeCheckingMode": "standard",
  "pythonVersion": "3.11",
  "include": [
    "backend",
    "tools",
    "app_pages",
    "app.py",
    "collect_fund_data.py",
    "db.py"
  ],
  "exclude": ["tests", ".venv", "venv", "data"],
  "reportMissingTypeStubs": false,
  "reportMissingParameterType": false,
  "reportUnknownMemberType": false
}
